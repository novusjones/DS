{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: 编译当前文件",
            "command": "D:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译当前打开的 .c 或 .cpp 文件"
        }
    ],
    "version": "2.0.0"
}